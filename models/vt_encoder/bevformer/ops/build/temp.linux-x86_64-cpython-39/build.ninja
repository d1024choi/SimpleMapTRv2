cflags = -march=nocona -mtune=haswell -ftree-vectorize -fPIC -fstack-protector-strong -fno-plt -O2 -ffunction-sections -pipe -isystem /home/dooseop/micromamba/envs/omnidrive/include -I/home/dooseop/micromamba/envs/omnidrive/targets/x86_64-linux/include -DNDEBUG -D_FORTIFY_SOURCE=2 -O2 -isystem /home/dooseop/micromamba/envs/omnidrive/include -I/home/dooseop/micromamba/envs/omnidrive/targets/x86_64-linux/include -fPIC -DWITH_CUDA -I/home/dooseop/Pytorch/Git/LLMBEV/BEVSemanticSeg_LLM/models/bevformer/ops/src -I/home/dooseop/micromamba/envs/omnidrive/lib/python3.9/site-packages/torch/include -I/home/dooseop/micromamba/envs/omnidrive/lib/python3.9/site-packages/torch/include/torch/csrc/api/include -I/home/dooseop/micromamba/envs/omnidrive/lib/python3.9/site-packages/torch/include/TH -I/home/dooseop/micromamba/envs/omnidrive/lib/python3.9/site-packages/torch/include/THC -I/home/dooseop/micromamba/envs/omnidrive/include -I/home/dooseop/micromamba/envs/omnidrive/include/python3.9 -c
post_cflags = -DTORCH_API_INCLUDE_EXTENSION_H '-DPYBIND11_COMPILER_TYPE="_gcc"' '-DPYBIND11_STDLIB="_libstdcpp"' '-DPYBIND11_BUILD_ABI="_cxxabi1011"' -DTORCH_EXTENSION_NAME=MultiScaleDeformableAttention -D_GLIBCXX_USE_CXX11_ABI=0 -std=c++17
cuda_cflags = -DWITH_CUDA -I/home/dooseop/Pytorch/Git/LLMBEV/BEVSemanticSeg_LLM/models/bevformer/ops/src -I/home/dooseop/micromamba/envs/omnidrive/lib/python3.9/site-packages/torch/include -I/home/dooseop/micromamba/envs/omnidrive/lib/python3.9/site-packages/torch/include/torch/csrc/api/include -I/home/dooseop/micromamba/envs/omnidrive/lib/python3.9/site-packages/torch/include/TH -I/home/dooseop/micromamba/envs/omnidrive/lib/python3.9/site-packages/torch/include/THC -I/home/dooseop/micromamba/envs/omnidrive/include -I/home/dooseop/micromamba/envs/omnidrive/include/python3.9 -c
cuda_post_cflags = -D__CUDA_NO_HALF_OPERATORS__ -D__CUDA_NO_HALF_CONVERSIONS__ -D__CUDA_NO_BFLOAT16_CONVERSIONS__ -D__CUDA_NO_HALF2_OPERATORS__ --expt-relaxed-constexpr --compiler-options ''"'"'-fPIC'"'"'' -DCUDA_HAS_FP16=1 -D__CUDA_NO_HALF_OPERATORS__ -D__CUDA_NO_HALF_CONVERSIONS__ -D__CUDA_NO_HALF2_OPERATORS__ -DTORCH_API_INCLUDE_EXTENSION_H '-DPYBIND11_COMPILER_TYPE="_gcc"' '-DPYBIND11_STDLIB="_libstdcpp"' '-DPYBIND11_BUILD_ABI="_cxxabi1011"' -DTORCH_EXTENSION_NAME=MultiScaleDeformableAttention -D_GLIBCXX_USE_CXX11_ABI=0 -gencode=arch=compute_60,code=sm_60 -gencode=arch=compute_61,code=sm_61 -gencode=arch=compute_70,code=sm_70 -gencode=arch=compute_75,code=sm_75 -gencode=arch=compute_80,code=sm_80 -gencode=arch=compute_86,code=sm_86 -gencode=arch=compute_89,code=sm_89 -gencode=arch=compute_90,code=sm_90 -ccbin /home/dooseop/micromamba/envs/omnidrive/bin/x86_64-conda-linux-gnu-cc -std=c++17
cuda_dlink_post_cflags = 
ldflags = 

rule compile
  command = $cxx -MMD -MF $out.d $cflags -c $in -o $out $post_cflags
  depfile = $out.d
  deps = gcc

rule cuda_compile
  depfile = $out.d
  deps = gcc
  command = $nvcc --generate-dependencies-with-compile --dependency-output $out.d $cuda_cflags -c $in -o $out $cuda_post_cflags





